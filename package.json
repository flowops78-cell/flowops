{
  "name": "flow-ops",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite --port=3000 --host=0.0.0.0",
    "build": "vite build",
    "preview": "vite preview --host 0.0.0.0 --port 4173",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit -p tsconfig.app.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "npm run lint:ui && npm run typecheck",
    "lint:ui": "eslint \"src/**/*.{ts,tsx}\"",
    "check": "npm run typecheck && npm run build",
    "debug:env": "node scripts/debug/check-env.mjs",
    "debug:migrations": "node scripts/debug/check-migrations.mjs",
    "debug:api": "node scripts/debug/check-postgrest.mjs",
    "debug:functions": "node scripts/debug/check-edge-function.mjs",
    "debug:app": "node scripts/debug/check-app.mjs",
    "debug:db": "node scripts/debug/check-db-cli.mjs",
    "debug:all": "node scripts/debug/run-all.mjs",
    "debug:all:local": "node scripts/debug/run-all.mjs --local",
    "deploy": "npm run build && wrangler deploy",
    "deploy:check": "npm run clean && npm run check"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.98.0",
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-react": "^5.0.4",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "papaparse": "^5.5.3",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^7.13.1",
    "recharts": "^3.7.0",
    "tailwind-merge": "^3.5.0",
    "uuid": "^13.0.0",
    "vite": "^6.2.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@typescript-eslint/parser": "^8.28.0",
    "@types/node": "^22.14.0",
    "@types/papaparse": "^5.5.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/uuid": "^10.0.0",
    "autoprefixer": "^10.4.21",
    "eslint": "^9.23.0",
    "jsdom": "^29.0.1",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.0",
    "vitest": "^3.2.4",
    "wrangler": "^4.77.0"
  }
}

