# ─────────────────────────────────────────────────────────────
# Flow Ops — environment template
# Copy to `.env`, fill all values, keep `.env` gitignored.
# Use one Supabase project: URL + ref + DB host must share the same project ref.
# ─────────────────────────────────────────────────────────────

# ── Supabase — browser (Vite) — Dashboard → Settings → API ──
# Use the public anon JWT or the newer publishable key (never the service_role key).
VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
# Optional: set to false to skip injecting <link rel="preconnect"> to VITE_SUPABASE_URL in built index.html
# VITE_SUPABASE_PRECONNECT=false
# Classic JWT “anon” key:
VITE_SUPABASE_ANON_KEY=your_supabase_anon_jwt
# Or newer key name (optional; either works):
# VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...

# ── Supabase — server / Edge / local scripts ─────────────────
# Same project URL and same public key as above; service role only on the server.
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_jwt
# Preferred in this repo + `supabase secrets set SB_SERVICE_ROLE_KEY=...`
SB_SERVICE_ROLE_KEY=your_service_role_jwt_or_sb_secret
# Legacy alias (optional; same value as SB_SERVICE_ROLE_KEY if set)
# SUPABASE_SERVICE_ROLE_KEY=

# ── Supabase CLI — https://supabase.com/dashboard/account/tokens
SUPABASE_ACCESS_TOKEN=your_personal_access_token
SUPABASE_PROJECT_REF=YOUR_PROJECT_REF

# ── Postgres (direct — Dashboard → Settings → Database) ─────
SUPABASE_DB_HOST=db.YOUR_PROJECT_REF.supabase.co
SUPABASE_DB_PORT=5432
SUPABASE_DB_USER=postgres
SUPABASE_DB_PASSWORD=your_database_password

# ── Seed accounts (local scripts only — not read by the Vite app) ──
# Primary admin — `npx tsx scripts/provision_admin.ts` (needs service role in .env)
FLOW_OPS_ADMIN_EMAIL=admin@example.com
FLOW_OPS_ADMIN_PASSWORD=choose_a_strong_password
# Extra test users — `npx tsx scripts/provision_secondary.ts`
# FLOW_OPS_ADMIN_2_EMAIL=
# FLOW_OPS_ADMIN_2_PASSWORD=
# FLOW_OPS_ADMIN_2_META_ORG_ID=
# FLOW_OPS_OPERATOR_EMAIL=
# FLOW_OPS_OPERATOR_PASSWORD=
# FLOW_OPS_OPERATOR_ORG_ID=

# ── Optional: GitHub — https://github.com/settings/tokens ─────
GITHUB_TOKEN=
GITHUB_OWNER=
GITHUB_REPO=
