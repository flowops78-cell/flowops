# ─────────────────────────────────────────────────────────────
# Flow Ops — Environment Template
# Copy to .env and fill in all values before running.
# ─────────────────────────────────────────────────────────────

# ── Supabase Project ──────────────────────────────────────────
# Dashboard → Project Settings → API
VITE_SUPABASE_URL=https://<project-ref>.supabase.co
VITE_SUPABASE_ANON_KEY=<anon-key>

# ── Supabase CLI ──────────────────────────────────────────────
# Generate at: https://supabase.com/dashboard/account/tokens
SUPABASE_ACCESS_TOKEN=<cli-access-token>
# Short ref from: supabase.com/dashboard/project/<this-part>
SUPABASE_PROJECT_REF=<project-ref>

# ── Admin Seed Account ────────────────────────────────────────
# First admin user — created via provision-user flow
FLOW_OPS_ADMIN_EMAIL=admin@admin.os
FLOW_OPS_ADMIN_PASSWORD=<min-8-chars>

# ── GitHub ───────────────────────────────────────────────────
# Repo: https://github.com/<owner>/<repo>
# Token: https://github.com/settings/tokens (repo scope)
GITHUB_TOKEN=<github-pat>
GITHUB_OWNER=<your-github-username-or-org>
GITHUB_REPO=flow-ops