# ─────────────────────────────────────────────────────────────
# Flow Ops — Environment Template (Refined)
# ─────────────────────────────────────────────────────────────

# --- Frontend ---
# Dashboard → Project Settings → API
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...

# --- CLI ---
# Short ref from Dashboard
SUPABASE_PROJECT_REF=your-project-ref
# Personal Access Token from User Account Settings
SUPABASE_ACCESS_TOKEN=sbp_...

# --- Edge Functions ---
# Project API URL
SUPABASE_URL=https://your-project.supabase.co
# Dashboard → Project Settings → API → Service Role Key (Secret)
# Note: Use 'sb_secret_...' format here.
SUPABASE_SERVICE_ROLE_KEY=sb_secret_...

# --- Admin Seed Account (Unrelated but preserved) ---
FLOW_OPS_ADMIN_EMAIL=admin@admin.os
FLOW_OPS_ADMIN_PASSWORD=...

# --- GitHub Integration (Unrelated but preserved) ---
GITHUB_TOKEN=ghp_...
GITHUB_OWNER=...
GITHUB_REPO=...